# Caddyfile — Tomo Verso Editora
# SSL automático via Let's Encrypt.
# O host Azure já resolve para a VPS. O domínio tomoverso.studio precisa existir no DNS e apontar A -> 40.116.106.139.

(tomoverso_proxy) {
    reverse_proxy tomoverso:3000 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }

    encode zstd gzip

    header /_next/static/* {
        Cache-Control "public, max-age=31536000, immutable"
    }

    log {
        output file /data/logs/tomoverso-access.log
    }
}

# Teste imediato por IP, sem SSL.
http://40.116.106.139 {
    import tomoverso_proxy
}

# Teste imediato pelo DNS público da Azure + domínio definitivo quando o DNS existir.
tomoversodn.northcentralus.cloudapp.azure.com, tomoverso.studio, www.tomoverso.studio {
    @www {
        host www.tomoverso.studio
    }
    redir @www https://tomoverso.studio{uri} permanent

    import tomoverso_proxy
}
