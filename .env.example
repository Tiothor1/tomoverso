# Tomo Verso Editora — environment template
# Never commit real secrets. Configure real values in Vercel Environment Variables.

# App
AUTH_SECRET=replace-with-a-long-random-secret-min-32-chars
NEXT_PUBLIC_SITE_URL=https://tomoverso.vercel.app
SUPPORT_EMAIL=tomoversoeditora@gmail.com

# Email verification — use Resend OR SMTP
RESEND_API_KEY=
EMAIL_FROM="Tomo Verso Editora <naoresponda@tomoverso.com>"

# SMTP (fallback se RESEND_API_KEY não estiver configurada)
# Para Gmail: use smtp.gmail.com, porta 587, secure=false
# 1. Ative "Senhas de app" na sua conta Google
# 2. Gere uma senha para "Outro dispositivo"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Supabase / Postgres
# DATABASE_URL is used by the direct Postgres helper. SUPABASE_DATABASE_URL may be set too.
DATABASE_URL=postgresql://postgres:***@db.your-project.supabase.co:5432/postgres?sslmode=require
SUPABASE_DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server/admin Supabase APIs need service_role. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=tomoverso

# Cloudflare / anti-bot
# Para proteção de formulário, crie um widget Turnstile no Cloudflare e preencha as duas chaves.
# Account/Zone ID sozinho não ativa o desafio.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Mercado Pago
MP_ACCESS_TOKEN=
NEXT_PUBLIC_MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
MP_TEST_MODE=false
