# Tomoverso environment template
# Never commit real secrets. Configure real values in Vercel Environment Variables.

# App
AUTH_SECRET=replace-with-a-long-random-secret-min-32-chars
NEXT_PUBLIC_SITE_URL=https://tomoverso.vercel.app
SUPPORT_EMAIL=support@tomoverso.com

# Email verification
RESEND_API_KEY=
EMAIL_FROM="Tomoverso <support@tomoverso.com>"

# Supabase — server secrets must NOT be NEXT_PUBLIC
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=tomoverso

# Mercado Pago — official production keys
MP_ACCESS_TOKEN=
NEXT_PUBLIC_MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
MP_TEST_MODE=false

# Optional Mercado Pago sandbox/test keys if needed later
MP_ACCESS_TOKEN_TEST=
NEXT_PUBLIC_MP_PUBLIC_KEY_TEST=
MP_WEBHOOK_SECRET_TEST=
