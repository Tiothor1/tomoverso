/data/tomoverso.db
/data/tomoverso.db-shm
/data/tomoverso.db-wal
/data/tomoverso.seed.db
/data/tomoverso.seed.db-shm
/data/tomoverso.seed.db-wal
/data/backups/
*.db
*.db-shm
*.db-wal
!/data/tomoverso.seed.db.gz

# Hermes / agent skill caches
.agents/
data/skills/
skills-lock.json

# misc
.DS_Store
*.pem
*.txt
!ads.txt
!robots.txt

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
